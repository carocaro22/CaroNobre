@page "/projects"

<div class="projects-grid">
    @foreach (var project in projects)
    {
        <a href="@project.Url"
            target="_blank"
            class="project-card">

            <img src="@project.ImageUrl"
                    alt="@project.Title"
                    class="project-image" />

            <div class="project-content">
                <h3>@project.Title</h3>
                <p>@project.Description</p>
            </div>

        </a>
    }

</div>
